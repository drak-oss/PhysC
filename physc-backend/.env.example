# ── Database ──────────────────────────────────────────────────────────────────
# Full JDBC connection string for your MySQL instance
DB_URL=jdbc:mysql://your-host:3306/physc_db?useSSL=true&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=physc_user
DB_PASSWORD=your_strong_password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=your_base64_encoded_secret_here

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
ALLOWED_ORIGINS=https://your-app.vercel.app

# ── Server ────────────────────────────────────────────────────────────────────
# PORT is set automatically by most hosting platforms; override only if needed
# PORT=8080
